<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mapper.SubmissionMapper">

    <resultMap id="BaseResultMap" type="com.domain.Submission">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="questionId" column="question_id" />
        <result property="language" column="language" />
        <result property="code" column="code" />
        <result property="status" column="status" />
        <result property="passCases" column="pass_cases" />
        <result property="totalCases" column="total_cases" />
        <result property="executionTime" column="execution_time" />
        <result property="errorMsg" column="error_msg" />
        <result property="aiAnalysis" column="ai_analysis" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <insert id="insert" parameterType="com.domain.Submission" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO submissions (
            user_id, question_id, language, code, status,
            pass_cases, total_cases, execution_time, error_msg, ai_analysis, create_time
        ) VALUES (
                     #{userId}, #{questionId}, #{language}, #{code}, #{status},
                     #{passCases}, #{totalCases}, #{executionTime}, #{errorMsg}, #{aiAnalysis}, NOW()
                 )
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM submissions WHERE id = #{id}
    </select>

</mapper>