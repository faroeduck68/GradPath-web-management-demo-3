<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mapper.AiQuestionMapper">

    <resultMap id="BaseResultMap" type="com.domain.AiQuestion">
        <id property="id" column="id" />
        <result property="creatorId" column="creator_id" />
        <result property="title" column="title" />
        <result property="difficulty" column="difficulty" />
        <result property="description" column="description" />
        <result property="inputFormat" column="input_format" />
        <result property="outputFormat" column="output_format" />
        <result property="sampleCase" column="sample_case" />
        <result property="testCasesJson" column="test_cases_json" />
        <result property="tags" column="tags" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <insert id="insert" parameterType="com.domain.AiQuestion" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_questions (
            creator_id, title, difficulty, description,
            input_format, output_format, sample_case,
            test_cases_json, tags, status, create_time
        ) VALUES (
                     #{creatorId}, #{title}, #{difficulty}, #{description},
                     #{inputFormat}, #{outputFormat}, #{sampleCase},
                     #{testCasesJson}, #{tags}, #{status}, NOW()
                 )
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM ai_questions WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM ai_questions ORDER BY create_time DESC
    </select>

    <select id="selectByPage" resultMap="BaseResultMap">
        SELECT * FROM ai_questions
        <where>
            <if test="keyword != null and keyword != ''">
                (title LIKE CONCAT('%', #{keyword}, '%')
                OR description LIKE CONCAT('%', #{keyword}, '%')
                OR tags LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        <if test="orderBy != null and orderBy != ''">
            ORDER BY
            <choose>
                <when test="orderBy == 'id'">id</when>
                <when test="orderBy == 'difficulty'">
                    CASE difficulty
                        WHEN '简单' THEN 1
                        WHEN '中等' THEN 2
                        WHEN '困难' THEN 3
                        ELSE 4
                    END
                </when>
                <otherwise>create_time</otherwise>
            </choose>
            <if test="orderDirection != null and orderDirection != ''">
                ${orderDirection}
            </if>
        </if>
        <if test="orderBy == null or orderBy == ''">
            ORDER BY create_time DESC
        </if>
    </select>

</mapper>